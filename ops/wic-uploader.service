[Unit]
Description=WIC Krakow 2026 uploader
After=network.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/uploader
EnvironmentFile=/home/ubuntu/uploader/uploader.env
ExecStart=/usr/bin/gunicorn -w 2 -b 127.0.0.1:5000 --access-logfile - --error-logfile - uploader_app:app
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
